<div class="dashboard-container">
    <h2>🛠️ Panel de Control - Bóveda Digital</h2>
    <div class="metrics-grid">
        <div class="metric-card">
            <h3>Fotos Protegidas</h3>
            <p class="number">{{ fotos }}</p>
        </div>
        <div class="metric-card">
            <h3>Mensajes en el Muro</h3>
            <p class="number">{{ notas }}</p>
        </div>
        <div class="metric-card">
            <h3>Estado del Sistema</h3>
            <p class="status-ok">ONLINE</p>
        </div>
    </div>
</div>
